# MySQL connection (Prisma)
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/rjapc_db"

# JWT secret for admin sessions (use a long random string in production)
JWT_SECRET="change-this-to-a-long-random-secret-in-production"

# Default admin (created by seed if not exists)
ADMIN_EMAIL="admin@rjapc.org"
ADMIN_PASSWORD="change-me-after-first-login"

# Public site URL (for metadata)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# WhatsApp (full international number, no +)
NEXT_PUBLIC_WHATSAPP_NUMBER="919876543210"
